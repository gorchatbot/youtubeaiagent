# Copy this file to .env and fill in whichever provider(s) you actually have
# a key for. You do NOT need all three - one is enough to run the app.
# The UI will only show providers that have a key set here.

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (https://aistudio.google.com/apikey) - has a free tier ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Groq (https://console.groq.com/keys) - fast + free tier, easiest to start with ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- App ---
# Comma-separated list of allowed origins for CORS. "*" is fine for local dev.
ALLOWED_ORIGINS=*
REQUEST_TIMEOUT_SECONDS=60
